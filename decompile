  decompile --no-ai <file-or-bundle> [output-dir]
  decompile --docker-image <image> <file-or-bundle> [output-dir]
  decompile --type <native|apk|aab|dex|jar|class|dotnet|ipa|app-bundle> <file> [output-dir]

