#!/usr/bin/env python3
"""Source-tree and distro-package wrapper for the decompile CLI."""

from pathlib import Path
import sys


def _add_packaged_paths() -> None:
    script = Path(__file__).resolve()
    candidates = [
        script.parent,
        script.parent.parent / "share" / "decompile",
        Path("/usr/local/share/decompile"),
        Path("/usr/share/decompile"),
    ]
    for candidate in candidates:
        if (candidate / "decompile_tool").is_dir():
            path = str(candidate)
            if path not in sys.path:
                sys.path.insert(0, path)


_add_packaged_paths()

from decompile_tool.cli import main


if __name__ == "__main__":
    raise SystemExit(main())
